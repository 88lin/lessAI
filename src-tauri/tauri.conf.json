{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LessAI",
  "version": "0.1.0",
  "identifier": "com.lessai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LessAI",
        "width": 1320,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
